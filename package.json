{
  "name": "daundulce",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npx nodemon server.js",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "build": "cd client && npm run build",
    "start": "cd server && node server.js",
    "seed": "cd server && node seed.js",
    "heroku-postbuild": "npm install --prefix client && npm run build && npm install --prefix server"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
